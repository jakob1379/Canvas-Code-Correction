---
site_name: Canvas Code Correction v2
site_author: Canvas Code Correction Maintainers
site_description: Prefect-based automation for Canvas submission correction
repo_url: https://github.com/jakob1379/Canvas-Code-Correction
repo_name: Canvas-Code-Correction
extra_css: [stylesheets/custom.css]
nav:
  - Tutorial (for Professors):
      - Introduction: tutorial/index.md
      - Prerequisites: tutorial/prerequisites.md
      - Creating a Grader Image: tutorial/creating-grader-image.md
      - Writing Grader Tests: tutorial/writing-grader-tests.md
  - Platform Setup (for Operators):
      - Configuring a Course: tutorial/configuring-course.md
      - Setting up Prefect: tutorial/setting-up-prefect.md
      - Scheduling Corrections: tutorial/scheduling-corrections.md
      - Monitoring Results: tutorial/monitoring-results.md
      - Deploying CCC: guides/deploying-tests-to-ccc.md
      - Prefect Agent: guides/prefect-agent.md
      - RustFS Storage: guides/rustfs-storage.md
  - Reference (Framework Docs):
      - Overview: index.md
      - Architecture: architecture.md
      - CLI Reference: reference/cli.md
      - Configuration: reference/configuration.md
      - API Clients: reference/api-clients.md
      - Grader Image Reference: guides/grader-image.md
      - Authoring Grader Tests Reference: guides/authoring-grader-tests.md
  - Current Development:
      - Roadmap: roadmap.md
      - Phase 2 Migration Plan: phase-2-migration-plan.md
      - Contributing: CONTRIBUTING.md
theme:
  name: material
  favicon: assets/logo.svg
  logo: assets/logo.svg
  palette:
    - media: '(prefers-color-scheme: light)'
      scheme: default
      primary: custom
      accent: custom
      toggle:
        icon: material/weather-night
        name: Switch to dark mode
    - media: '(prefers-color-scheme: dark)'
      scheme: slate
      primary: custom
      accent: custom
      toggle:
        icon: material/weather-sunny
        name: Switch to light mode
  features:
    - content.code.annotate
    - content.code.copy
    - content.tabs.link
    - navigation.expand
    - navigation.footer
    - navigation.instant
    - navigation.instant.prefetch
    - navigation.instant.progress
    - navigation.prune
    - navigation.sections
    - navigation.tabs
    - navigation.tabs.sticky
    - navigation.top
    - navigation.tracking
    - search.highlight
    - search.suggest
    - toc.follow
extra:
  social:
    - icon: fontawesome/brands/github
      link: https://github.com/jakob1379/Canvas-Code-Correction
copyright: Copyright &copy; 2026 Canvas Code Correction Maintainers
markdown_extensions:
  - toc:
      permalink: true
  - admonition
  - attr_list
  - md_in_html
  - pymdownx.details
  - pymdownx.snippets
  - pymdownx.tabbed:
      alternate_style: true
  - pymdownx.superfences
  - pymdownx.highlight:
      anchor_linenums: true
      line_spans: __span
      pygments_lang_class: true
  - pymdownx.inlinehilite
  - pymdownx.blocks.caption
  - pymdownx.emoji
plugins: [search, mermaid2, glightbox]
