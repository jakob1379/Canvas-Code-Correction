# Development Environment Variables
# Copy to .env for local development with: cp .env.dev .env
# Docker Compose will use these values for local development

# Canvas API Configuration (required for integration tests)
CANVAS_API_URL=https://canvas.instructure.com
CANVAS_API_TOKEN=your_canvas_api_token_here
CANVAS_COURSE_ID=123456

# Docker Compose Database Configuration
POSTGRES_PASSWORD=dev_prefect

# Optional overrides for local development
CCC_WORKING_DIR=/tmp/ccc/runs
CCC_WORKSPACE_ROOT=/tmp/ccc/workspaces

# RustFS Configuration for local development
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET_NAME=test-assets
RUSTFS_PREFIX=dev

# Prefect Configuration for local development
PREFECT_API_URL=http://localhost:4200/api
PREFECT_API_KEY=your_prefect_api_key_here

# Test Assignment ID (for integration tests)
CANVAS_TEST_ASSIGNMENT_ID=59160606

# Asset Storage Configuration (optional for local development)
# CCC_ASSETS_S3_ENDPOINT=https://s3.amazonaws.com
# CCC_ASSETS_S3_ACCESS_KEY=your_access_key
# CCC_ASSETS_S3_SECRET_KEY=your_secret_key
# CCC_ASSETS_S3_BUCKET=course-assets
# CCC_ASSETS_S3_PREFIX=graders/course-slug/
